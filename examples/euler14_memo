# Project Euler #14, recursive + @memo.
# Algorithmic angle: subchains overlap, so memoization should turn 100M ops into
# something far smaller. Empirical question: does memo's dict overhead beat
# pypy's JIT on the iterative tight loop?
# only runnable via:  ./run pps examples/euler14_memo
import time, sys

sys.setrecursionlimit(2000)

@memo
def chain_len(n):
    if n == 1: return 1
    if n % 2 == 0: return 1 + chain_len(n // 2)
    return 1 + chain_len(3 * n + 1)

def main():
    best_n, best_c = 0, 0
    for i in range(1, 1_000_000):
        c = chain_len(i)
        if c > best_c:
            best_n, best_c = i, c
    return best_n, best_c

t0 = time.perf_counter()
n, c = main()
dt = time.perf_counter() - t0
info(f"answer: n={n} chain={c}  time={dt:.3f}s")
