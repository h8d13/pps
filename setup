#!/bin/bash
STRUCS="src src/utils"

PYPY_BIN=$(command -v pypy3) || { echo "pypy3 not found - install via package manager"; exit 1; }

if [ ! -d ".venv" ]; then
  echo "Creating venv..."
  "$PYPY_BIN" -m venv .venv
fi

cat > run << 'RUN'
#!/bin/sh
exec "$(dirname "$0")/.venv/bin/pypy3" "$@"
RUN
chmod +x run
echo "./run --> .venv/bin/pypy3 (wrapper)"

if [ -z "$NO_PIP" ]; then
  echo "Upgrading pip..."
  .venv/bin/pip install --upgrade pip 2>/dev/null
fi

[ -f pps ] || { echo "error: pps file missing alongside setup"; exit 1; }
chmod +x pps

REQ_STRUCS="${2:-}"
REQ_LINT="${3:-}"

if [ -n "$REQ_STRUCS" ]; then
  for d in $STRUCS; do
    mkdir -p "$REQ_STRUCS/$d"
  done
  if [ -n "$REQ_LINT" ]; then
    ./run pps -i ruff
    cat > "$REQ_STRUCS/pyproject.toml" << EOF
[project]
name = "$REQ_STRUCS"

[tool.ruff]
line-length = 120
target-version = "py311"
include = ["src/**/*"]
builtins = ["load_mod", "load_def", "load_run", "exc", "attempt"]

[tool.ruff.format]
quote-style = "single"
docstring-code-format = true

[tool.ruff.lint]
select = [
    "B",      # flake8-bugbear
    "C4",     # flake8-comprehensions
    "E",      # pycodestyle errors
    "F",      # pyflakes
    "FURB",   # refurb
    "PERF",   # perflint
    "PIE",    # flake8-pie
    "RET",    # flake8-return
    "RSE",    # flake8-raise
    "RUF",    # ruff-specific
    "SIM",    # flake8-simplify
    "UP",     # pyupgrade
    "W",      # pycodestyle warnings
]

[tool.ruff.lint.mccabe]
max-complexity = 20
EOF
  fi
  if [ -n "$BARE" ]; then
    cat > "$REQ_STRUCS/src/main" << 'EOF'
raise SystemExit(0)
EOF
  else
    cat > "$REQ_STRUCS/src/main" << 'EOF'
# info, warn, error, debug, set_level, memo, exc, attempt are built-in

info("Starting up")

val, err = attempt(int, "42")
info("parsed:", val)

val, err = attempt(int, "nope")
if err: warn(err); val = 0
info("fallback:", val)
EOF
  fi
fi

./run -c "print('PPS Operational.')" | { grep "PPS"; echo "Use: ./run pps -h"; } || { echo "Failed to setup PPS"; exit 1; }